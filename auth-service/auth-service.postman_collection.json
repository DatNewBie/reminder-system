						"header": [
							{
								"key": "Authorization",
								"value": "Bearer expired_token_here",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/auth/refresh",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"refresh"
							]
						},
						"description": "Example of refresh with expired or invalid token"
					},
					"response": []
				}
			],
			"description": "Example requests showing error scenarios"
		},
