# PostgreSQL
POSTGRES_DB=reminder_db
POSTGRES_USER=reminder_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_EMAIL=admin@reminder.com
PGADMIN_PASSWORD=your_admin_password
PGADMIN_PORT=5050

# Spring Boot - Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/reminder_db
SPRING_DATASOURCE_USERNAME=reminder_user
SPRING_DATASOURCE_PASSWORD=your_password_here

# Service Ports
API_GATEWAY_PORT=8080
REMINDER_SERVICE_PORT=8081
NOTIFICATION_SERVICE_PORT=8083