# PostgreSQL
POSTGRES_DB=reminder_db
POSTGRES_USER=reminder_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_EMAIL=admin@reminder.com
PGADMIN_PASSWORD=your_admin_password
PGADMIN_PORT=5050

# Spring Boot - Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/reminder_db
SPRING_DATASOURCE_USERNAME=reminder_user
SPRING_DATASOURCE_PASSWORD=your_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# RabbitMQ - Exchanges & Queues
RABBITMQ_EXCHANGE=reminder.exchange
RABBITMQ_DLX=reminder.dlx

# RabbitMQ - Email Channel
RABBITMQ_EMAIL_QUEUE=reminder.email.queue
RABBITMQ_EMAIL_ROUTING_KEY=reminder.email
RABBITMQ_EMAIL_DLQ=reminder.email.dlq

# RabbitMQ - SMS Channel
RABBITMQ_SMS_QUEUE=reminder.sms.queue
RABBITMQ_SMS_ROUTING_KEY=reminder.sms
RABBITMQ_SMS_DLQ=reminder.sms.dlq

# RabbitMQ - Push Channel
RABBITMQ_PUSH_QUEUE=reminder.push.queue
RABBITMQ_PUSH_ROUTING_KEY=reminder.push
RABBITMQ_PUSH_DLQ=reminder.push.dlq

# Service Ports
API_GATEWAY_PORT=8080
REMINDER_SERVICE_PORT=8081
SCHEDULER_SERVICE_PORT=8082
NOTIFICATION_SERVICE_PORT=8083